# Database (dev) — uses non-superuser role for RLS enforcement
DATABASE_URL="postgresql://retailedge_app:retailedge_app_dev@localhost:5433/retailedge_dev"

# Database (test) — used by Vitest, same non-superuser role
DATABASE_URL_TEST="postgresql://retailedge_app:retailedge_app_dev@localhost:5433/retailedge_test"

# Database (admin) — superuser for migrations only
DATABASE_URL_ADMIN="postgresql://retailedge:retailedge_dev@localhost:5433/retailedge_dev"

# JWT
JWT_SECRET="change-me-to-a-random-string"

# Server
PORT=3001
NODE_ENV=development

# Claude API (for OCR and matching)
ANTHROPIC_API_KEY="sk-ant-..."

# Stripe Billing (use TEST keys only — never production in dev/test)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_PRO="price_..."

# App URL (for Stripe Checkout redirect URLs)
APP_URL="http://localhost:5174"
