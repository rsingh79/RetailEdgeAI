// ─────────────────────────────────────────────────────────────────────────────
// PHASE 1: Chat & Conversations
// ─────────────────────────────────────────────────────────────────────────────

model ChatConversation {
  id            String     @id @default(uuid())
  tenantId      String
  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  title         String?                       // Auto-generated from first message
  status        ChatStatus @default(ACTIVE)
  messageCount  Int        @default(0)
  lastMessageAt DateTime?
  summary       String?                       // Rolling conversation summary
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  messages      ChatMessage[]

  @@index([tenantId, userId, createdAt])
  @@index([tenantId, status])
}

model ChatMessage {
  id              String      @id @default(uuid())
  conversationId  String
  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            MessageRole
  content         String                      // Message text (markdown supported)
  metadata        Json?                       // Tool calls used, sources, resolution details
  tokenCount      Int?                        // Total tokens for this message
  costUsd         Float?                      // Estimated cost in USD
  resolutionLevel Int?                        // 1=template, 2=KB, 3=internal, 4=external, 5=strategy
  createdAt       DateTime    @default(now())

  feedback        ChatFeedback?

  @@index([conversationId, createdAt])
}

model ChatFeedback {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  messageId String   @unique                  // One feedback per message
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  score     Int                               // 1 = thumbs down, 5 = thumbs up
  reason    String?                           // Optional feedback text
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

enum ChatStatus {
  ACTIVE
  ARCHIVED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}


