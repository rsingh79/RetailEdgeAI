generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Multi-tenant ──

model Tenant {
  id                  String   @id @default(cuid())
  name                String
  abn                 String?
  timezone            String   @default("Australia/Sydney")
  currency            String   @default("AUD")
  contactEmail        String?
  contactPhone        String?
  trialEndsAt         DateTime?
  isLocked            Boolean  @default(false)
  lockReason          String?
  lockedAt            DateTime?
  lockedBy            String?
  subscriptionStatus  String   @default("trial")   // trial, active, cancelled, expired
  paymentMethodOnFile Boolean  @default(false)
  maxUsers            Int      @default(5)
  maxStores           Int      @default(2)
  maxApiCallsPerMonth Int      @default(100)
  plan                String   @default("starter")  // starter, professional, enterprise
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users               User[]
  stores              Store[]
  suppliers           Supplier[]
  products            Product[]
  invoices            Invoice[]
  pricingRules        PricingRule[]
  auditLogs           AuditLog[]
  importTemplates     ImportTemplate[]
  apiUsageLogs        ApiUsageLog[]
  accessLogs          TenantAccessLog[]
  gmailIntegrations   GmailIntegration[]
  gmailImportLogs     GmailImportLog[]
  folderIntegration   FolderIntegration?
  folderImportLogs    FolderImportLog[]
  competitorMonitors  CompetitorMonitor[]
  competitorPrices    CompetitorPrice[]
  priceAlerts         PriceAlert[]
  shopifyIntegration  ShopifyIntegration?
  shopifyImportLogs   ShopifyImportLog[]
  driveIntegrations   DriveIntegration[]
  driveImportLogs     DriveImportLog[]
  planTierId          String?
  planTier            PlanTier?  @relation(fields: [planTierId], references: [id])
  conversations            Conversation[]
  tenantSourceRegistries   TenantSourceRegistry[]
  importJobs               ImportJob[]
  approvalQueueEntries     ApprovalQueueEntry[]
  productImportRecords     ProductImportRecord[]
  aiServiceLogs            AiServiceLog[]
  productEmbeddings        ProductEmbedding[]
}

// ── Auth ──

model User {
  id           String   @id @default(cuid())
  tenantId     String?
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(STORE_MANAGER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant               Tenant?        @relation(fields: [tenantId], references: [id])
  auditLogs            AuditLog[]
  conversations        Conversation[]
  importJobs           ImportJob[]
  approvalQueueEntries ApprovalQueueEntry[] @relation("ApprovalActionUser")

  @@index([tenantId])
}

enum Role {
  OWNER
  OPS_MANAGER
  MERCHANDISER
  STORE_MANAGER
  ACCOUNTANT
  SYSTEM_ADMIN
}

// ── Stores ──

model Store {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  type       StoreType
  platform   String?   // e.g. "Lightspeed", "Shopify", "WooCommerce"
  apiConfig  Json?     // encrypted connection details
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  productVariants ProductVariant[]

  @@index([tenantId])
}

enum StoreType {
  POS
  ECOMMERCE
}

// ── Products ──

model Product {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  category   String?
  baseUnit   String?  // e.g. "kg", "each", "litre"
  barcode    String?
  costPrice  Float?   // supplier/wholesale cost
  sellingPrice Float? // retail selling price
  source     String   @default("Manual") // POS/ecommerce system (e.g. "Lightspeed", "Shopify")
  archivedAt DateTime?                  // soft-delete: set instead of deleting

  // ── Product Import Pipeline Fields ──────────────────────────
  // Source system native record ID (e.g. Shopify product ID)
  externalId              String?
  // How the product entered RetailEdgeAI — maps to SourceType enum values
  productImportedThrough  String?
  // SHA-256 hash of normalised identity fields for dedup
  fingerprint             String?
  // FK to ImportJob — relation wired to ImportJob model
  importId                String?
  // Self-referential FK — points to master record if this is a duplicate
  canonicalProductId      String?
  // Import-time approval state — null for pre-pipeline products
  approvalStatus          ImportApprovalStatus?
  // Last successful sync from source — distinct from updatedAt
  lastSyncedAt            DateTime?
  // Confidence score 0.0-1.0 assigned at import time by Confidence Scorer
  confidenceScore         Float?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant             Tenant                @relation(fields: [tenantId], references: [id])
  importJob          ImportJob?            @relation("ProductImportJob", fields: [importId], references: [id])
  importRecords      ProductImportRecord[]
  variants           ProductVariant[]
  competitorMonitors CompetitorMonitor[]
  priceAlerts        PriceAlert[]
  invoiceMatches     InvoiceLineMatch[]
  embeddings         ProductEmbedding[]

  @@index([tenantId])
  @@index([barcode])
  @@index([tenantId, externalId])
  @@index([fingerprint])
  @@index([importId])
  @@index([canonicalProductId])
  @@index([approvalStatus])
}

model ProductVariant {
  id               String  @id @default(cuid())
  productId        String
  storeId          String
  sku              String
  name             String
  size             String? // e.g. "1kg", "250g", "Dozen"
  unitQty          Float   @default(1) // how many base units this variant represents
  currentCost      Float   @default(0)
  salePrice        Float   @default(0)
  shelfLocation    String?
  isActive         Boolean @default(true)
  shopifyVariantId String? // Shopify variant ID for API price push
  shopifyProductId String? // Shopify product ID for reference
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product          Product              @relation(fields: [productId], references: [id])
  store            Store                @relation(fields: [storeId], references: [id])
  invoiceMatches   InvoiceLineMatch[]
  shopifyOrderLines ShopifyOrderLine[]

  @@unique([storeId, sku])
  @@index([productId])
  @@index([storeId])
  @@index([shopifyVariantId])
}

// ── Suppliers ──

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  abn       String?
  email     String?
  phone        String?
  gstInclusive  Boolean  @default(false) // does this supplier's line prices include GST?
  hasPerLineGst Boolean  @default(false) // does this supplier show per-line GST amounts on invoices?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  invoices Invoice[]
  mappings SupplierProductMapping[]

  @@index([tenantId])
}

// ── Invoices ──

model Invoice {
  id              String        @id @default(cuid())
  tenantId        String
  supplierId      String?
  supplierName    String?       // as detected by OCR
  invoiceNumber   String?
  invoiceDate     DateTime?
  dueDate         DateTime?
  subtotal        Float?
  gst             Float?
  freight         Float?
  total           Float?
  freightMethod   FreightMethod @default(PROPORTIONAL_VALUE)
  gstInclusive    Boolean       @default(false)  // are line prices GST-inclusive?
  status          InvoiceStatus @default(PROCESSING)
  ocrConfidence   Float?
  originalFileUrl String?
  source          String        @default("manual")  // "manual" or "email"
  gmailMessageId  String?
  archivedAt      DateTime?                         // soft-delete: set instead of deleting
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  supplier Supplier?     @relation(fields: [supplierId], references: [id])
  lines    InvoiceLine[]

  @@index([tenantId])
  @@index([supplierId])
}

enum InvoiceStatus {
  PROCESSING
  READY
  IN_REVIEW
  APPROVED
  EXPORTED
  FAILED
  DISCARDED   // document was not an invoice (e.g. statement, receipt, PO)
}

enum FreightMethod {
  EQUAL_SPLIT
  PROPORTIONAL_VALUE
  PROPORTIONAL_QTY
  MANUAL
}

model InvoiceLine {
  id               String  @id @default(cuid())
  invoiceId        String
  lineNumber       Int
  description      String  // as shown on invoice
  quantity         Float
  unitPrice        Float
  lineTotal        Float
  freightAlloc     Float   @default(0)
  gstAlloc         Float   @default(0)
  gstApplicable    Boolean @default(true)  // does this line item attract GST?
  lineGstAmount    Float?  // per-line GST amount extracted from invoice (null if no per-line GST column)
  packSize         String? // e.g. "10kg bag", "Tray x30"
  baseUnit         String? // e.g. "kg", "each"
  baseUnitCost     Float?  // normalized cost per base unit
  ocrConfidence    Float?
  status           LineStatus @default(PENDING)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  invoice Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  matches InvoiceLineMatch[]

  @@index([invoiceId])
}

enum LineStatus {
  PENDING
  MATCHED
  NEEDS_REVIEW
  APPROVED
  HELD
  FLAGGED
}

model InvoiceLineMatch {
  id               String      @id @default(cuid())
  invoiceLineId    String
  productVariantId String?     // null for product-level matches (no variant)
  productId        String?     // direct product ref for variant-less matches
  confidence       Float       @default(0)
  matchReason      String?     // e.g. "barcode", "sku", "fuzzy_name"
  isManual         Boolean     @default(false)
  matchedByUserId  String?
  previousCost     Float?
  newCost          Float?
  currentPrice     Float?
  suggestedPrice   Float?
  approvedPrice    Float?
  exportFlagged    Boolean     @default(false) // true when user overrode the sell price
  exportedAt       DateTime?   // null = not exported, date = when exported
  status           MatchStatus @default(PENDING)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  invoiceLine    InvoiceLine     @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])
  product        Product?        @relation(fields: [productId], references: [id])

  @@index([invoiceLineId])
  @@index([productVariantId])
  @@index([productId])
}

enum MatchStatus {
  PENDING
  CONFIRMED
  REJECTED
  APPROVED
  EXPORTED
}

// ── Supplier-Product Mappings (for reuse) ──

model SupplierProductMapping {
  id                  String   @id @default(cuid())
  supplierId          String
  supplierDescription String   // invoice line description
  supplierSku         String?
  productId           String
  confidence          Float    @default(1)
  confirmedByUserId   String?
  timesUsed           Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([supplierDescription])
}

// ── Pricing Rules ──

model PricingRule {
  id             String        @id @default(cuid())
  tenantId       String
  name           String
  scope          RuleScope
  scopeValue     String?       // category name, supplier id, or product id
  targetMargin   Float?
  minMargin      Float?
  maxPriceJump   Float?        // max % increase allowed
  roundingStrategy String?     // ".99", ".49/.99", "nearest_5"
  isActive       Boolean       @default(true)
  priority       Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

enum RuleScope {
  GLOBAL
  CATEGORY
  SUPPLIER
  PRODUCT
}

// ── Import Templates ──

model ImportTemplate {
  id         String   @id @default(cuid())
  tenantId   String
  systemName String
  mapping    Json     // { internalField: externalColumnHeader }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, systemName])
  @@index([tenantId])
}

// ── Audit ──

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  action      String   // e.g. "INVOICE_APPROVED", "PRICE_UPDATED", "MATCH_CONFIRMED"
  entityType  String   // e.g. "Invoice", "ProductVariant"
  entityId    String
  previousVal Json?
  newVal      Json?
  metadata    Json?
  // FK to ImportJob — relation added when ImportJob model is created
  importJobId      String?
  triggerSource    AuditTriggerSource @default(SYSTEM_PROCESS)
  triggerFunction  String?
  triggerContext   Json?
  createdAt   DateTime @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])
  importJob ImportJob? @relation(fields: [importJobId], references: [id])

  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([importJobId])
}

// ── Platform Settings (singleton) ──

model PlatformSettings {
  id                    String   @id @default("singleton")
  defaultTrialDays      Int      @default(14)
  autoLockOnTrialExpiry Boolean  @default(true)
  gracePeriodDays       Int      @default(3)
  updatedAt             DateTime @updatedAt
}

// ── API Usage Tracking ──

model ApiUsageLog {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String?
  endpoint        String   // "ocr", "chat", etc.
  model           String?  // Claude model name
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  totalTokens     Int      @default(0)
  costUsd         Float    @default(0)
  requestPayload  Json?
  responsePayload Json?
  durationMs      Int?
  status          String   @default("success") // "success" | "error"
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
  @@index([tenantId, createdAt])
}

// ── Tenant Access Log ──

model TenantAccessLog {
  id          String   @id @default(cuid())
  tenantId    String
  action      String   // "LOCKED", "UNLOCKED", "REGISTERED"
  reason      String?
  performedBy String?  // userId of admin who performed action
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
}

// ── Gmail Integration ──

model GmailIntegration {
  id                    String    @id @default(cuid())
  tenantId              String
  googleClientId        String?                      // tenant's own Google OAuth Client ID
  googleClientSecretEnc String?                      // AES-256-GCM encrypted Client Secret
  email                 String?                      // connected Gmail address (set after OAuth)
  accessTokenEnc        String?                      // AES-256-GCM encrypted (set after OAuth)
  refreshTokenEnc       String?                      // AES-256-GCM encrypted (set after OAuth)
  tokenExpiresAt        DateTime?
  connectionType        String    @default("oauth")   // "oauth" | "imap"
  imapHost              String?                      // e.g. "imap.gmail.com"
  imapPort              Int?      @default(993)
  imapEmail             String?                      // email address for IMAP login
  imapPasswordEnc       String?                      // AES-256-GCM encrypted App Password
  imapUseSsl            Boolean   @default(true)
  imapLastUid           Int?      @default(0)        // last processed UID for incremental fetch
  historyId             String?                      // Gmail history ID for incremental sync
  lastPollAt            DateTime?
  pollIntervalMin       Int       @default(30)
  initialLookbackDays   Int       @default(7)          // how far back to search on first poll
  isActive              Boolean   @default(true)
  senderWhitelist       String[]  @default([])       // email addresses to filter
  labelFilter           String?                      // Gmail label to filter
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, imapEmail])
  @@index([tenantId])
}

model GmailImportLog {
  id              String    @id @default(cuid())
  tenantId        String
  gmailMessageId  String                           // Dedup layer 1: Gmail message ID
  fileHash        String?                          // Dedup layer 2: SHA-256 of attachment
  supplierName    String?                          // Dedup layer 3 component
  invoiceNumber   String?                          // Dedup layer 3 component
  invoiceDate     DateTime?                        // Dedup layer 3 component
  senderEmail     String
  subject         String?
  attachmentName  String
  status          String    @default("imported")   // imported, duplicate, failed, skipped
  duplicateReason String?                          // "message_id", "file_hash", "invoice_match"
  invoiceId       String?                          // linked Invoice if imported
  createdAt       DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, gmailMessageId])
  @@index([tenantId])
  @@index([tenantId, fileHash])
  @@index([tenantId, invoiceNumber, invoiceDate])
}

// ── Folder Polling Integration ──

model FolderIntegration {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  folderPath       String?                          // local or UNC path, e.g. "C:\Invoices" or "\\server\share"
  lastPollAt       DateTime?
  pollIntervalMin  Int       @default(30)
  isActive         Boolean   @default(true)
  filePatterns     String[]  @default(["*.pdf", "*.jpg", "*.jpeg", "*.png", "*.webp"])
  moveToProcessed  Boolean   @default(true)         // move files to Processed/ subfolder after import
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model FolderImportLog {
  id              String    @id @default(cuid())
  tenantId        String
  filePath        String                           // Dedup layer 1: original file path
  fileHash        String?                          // Dedup layer 2: SHA-256 of file contents
  supplierName    String?                          // Dedup layer 3 component
  invoiceNumber   String?                          // Dedup layer 3 component
  invoiceDate     DateTime?                        // Dedup layer 3 component
  fileName        String
  fileSize        Int                              // file size in bytes
  status          String    @default("imported")   // imported, duplicate, failed, skipped
  duplicateReason String?                          // "file_path", "file_hash", "content_match"
  invoiceId       String?                          // linked Invoice if imported
  createdAt       DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, filePath])
  @@index([tenantId])
  @@index([tenantId, fileHash])
  @@index([tenantId, invoiceNumber, invoiceDate])
}

// ── Shopify Integration ──

model ShopifyIntegration {
  id                  String    @id @default(cuid())
  tenantId            String    @unique
  shop                String                          // e.g. "mystore.myshopify.com"
  accessTokenEnc      String?                         // AES-256-GCM encrypted Shopify access token
  scopes              String    @default("read_products,write_products,read_orders,read_customers")
  lastSyncAt          DateTime?
  lastOrderSyncAt     DateTime?                       // last time orders were synced
  syncIntervalMin     Int       @default(60)
  isActive            Boolean   @default(true)
  pushPricesOnExport  Boolean   @default(true)        // auto-push cost+price to Shopify on invoice export
  productCount        Int       @default(0)
  orderCount          Int       @default(0)           // cached count of synced orders
  dismissedVariants   Json?     @default("[]")        // Shopify variant IDs dismissed from matching
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  orders      ShopifyOrder[]

  @@index([tenantId])
}

model ShopifyImportLog {
  id              String   @id @default(cuid())
  tenantId        String
  status          String   @default("success")    // success, partial, failed
  productsPulled  Int      @default(0)
  productsCreated Int      @default(0)
  productsUpdated Int      @default(0)
  variantsCreated Int      @default(0)
  ordersPulled    Int      @default(0)
  ordersCreated   Int      @default(0)
  ordersUpdated   Int      @default(0)
  errors          Json?
  durationMs      Int?
  syncType        String   @default("products")   // "products" | "orders" | "full"
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
}

// ── Shopify Orders ──

model ShopifyOrder {
  id                String    @id @default(cuid())
  tenantId          String
  shopifyOrderId    String                          // Shopify's numeric order ID
  shopifyOrderName  String?                         // e.g. "#1001"
  integrationId     String
  orderDate         DateTime
  customerName      String?
  customerEmail     String?
  financialStatus   String?                         // paid, pending, refunded, etc.
  fulfillmentStatus String?                         // fulfilled, partial, unfulfilled
  totalPrice        Float     @default(0)
  subtotalPrice     Float     @default(0)
  totalTax          Float     @default(0)
  currency          String    @default("AUD")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  integration ShopifyIntegration @relation(fields: [integrationId], references: [id])
  lines       ShopifyOrderLine[]

  @@unique([integrationId, shopifyOrderId])
  @@index([tenantId])
  @@index([orderDate])
}

model ShopifyOrderLine {
  id               String  @id @default(cuid())
  orderId          String
  shopifyLineId    String
  productVariantId String?                         // linked to our ProductVariant if matched
  sku              String?
  productTitle     String?
  variantTitle     String?
  quantity         Int     @default(1)
  unitPrice        Float   @default(0)
  totalPrice       Float   @default(0)
  createdAt        DateTime @default(now())

  order   ShopifyOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
  @@index([productVariantId])
}

// ── Google Drive Integration ──

model DriveIntegration {
  id                    String    @id @default(cuid())
  tenantId              String
  googleClientId        String?                    // tenant's own Google OAuth Client ID
  googleClientSecretEnc String?                    // AES-256-GCM encrypted Client Secret
  email                 String?                    // Google account email (set after OAuth)
  accessTokenEnc        String?                    // AES-256-GCM encrypted access token
  refreshTokenEnc String?                          // AES-256-GCM encrypted refresh token
  tokenExpiresAt  DateTime?
  driveFolderId   String                           // Google Drive folder ID selected by user
  driveFolderName String?                          // Display name of the selected folder
  lastPollAt      DateTime?
  pollIntervalMin Int       @default(30)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, driveFolderId])
  @@index([tenantId])
}

model DriveImportLog {
  id              String    @id @default(cuid())
  tenantId        String
  driveFileId     String                           // Dedup layer 1: Google Drive file ID
  fileHash        String?                          // Dedup layer 2: SHA-256 of file contents
  supplierName    String?                          // Dedup layer 3 component
  invoiceNumber   String?                          // Dedup layer 3 component
  invoiceDate     DateTime?                        // Dedup layer 3 component
  fileName        String                           // Original filename from Drive
  fileSize        Int                              // File size in bytes
  mimeType        String?                          // MIME type from Drive metadata
  status          String    @default("imported")   // imported, duplicate, failed, skipped
  duplicateReason String?                          // "drive_file_id", "file_hash", "content_match"
  invoiceId       String?                          // linked Invoice if imported
  createdAt       DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, driveFileId])
  @@index([tenantId])
  @@index([tenantId, fileHash])
  @@index([tenantId, invoiceNumber, invoiceDate])
}

// ── Competitor Intelligence ──

model CompetitorMonitor {
  id            String    @id @default(cuid())
  tenantId      String
  competitor    String                             // "woolworths", "coles", "aldi", "iga"
  productId     String                             // RetailEdge product to compare
  externalUrl   String?                            // competitor product page URL
  externalSku   String?                            // competitor product code
  searchTerm    String?                            // search term for matching
  isActive      Boolean   @default(true)
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant  Tenant            @relation(fields: [tenantId], references: [id])
  product Product           @relation(fields: [productId], references: [id])
  prices  CompetitorPrice[]

  @@index([tenantId])
  @@index([productId])
  @@index([competitor])
}

model CompetitorPrice {
  id                  String    @id @default(cuid())
  tenantId            String
  competitorMonitorId String
  price               Float
  unitPrice           Float?                       // price per base unit (e.g. per kg)
  unit                String?                      // "kg", "each", "litre"
  isOnSpecial         Boolean   @default(false)
  specialEndDate      DateTime?
  scrapedAt           DateTime  @default(now())

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  competitorMonitor CompetitorMonitor @relation(fields: [competitorMonitorId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([competitorMonitorId])
  @@index([scrapedAt])
}

model PriceAlert {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String
  alertType   String                               // "competitor_undercut", "margin_squeeze", "cost_increase", "price_opportunity"
  severity    String   @default("info")            // "info", "warning", "critical"
  title       String
  description String
  metadata    Json?                                // competitor, prices, margins, etc.
  isRead      Boolean  @default(false)
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([tenantId, isRead])
  @@index([productId])
  @@index([createdAt])
}

// ── Feature & Plan Tier Management ──

model Feature {
  id          String   @id @default(cuid())
  key         String   @unique             // unique slug e.g. "invoices", "email_integration"
  name        String                       // display name e.g. "Email Integration"
  description String?
  icon        String?                      // emoji or icon name
  category    String   @default("general") // "core", "integrations", "pricing", "intelligence"
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  isCore      Boolean  @default(false)     // core features cannot be removed from any tier
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tiers PlanTierFeature[]
}

model PlanTier {
  id           String   @id @default(cuid())
  name         String                       // "Basic", "Medium", "High"
  slug         String   @unique             // "basic", "medium", "high"
  description  String?
  monthlyPrice Float    @default(0)
  annualPrice  Float    @default(0)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)     // new tenants get this tier
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  features PlanTierFeature[]
  limits   PlanTierLimit[]
  tenants  Tenant[]
}

model PlanTierFeature {
  planTierId String
  featureId  String

  planTier PlanTier @relation(fields: [planTierId], references: [id], onDelete: Cascade)
  feature  Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([planTierId, featureId])
  @@index([featureId])
}

model PlanTierLimit {
  id          String  @id @default(cuid())
  planTierId  String
  limitKey    String                        // e.g. "max_users", "max_invoice_pages_per_month"
  limitValue  Int
  description String?

  planTier PlanTier @relation(fields: [planTierId], references: [id], onDelete: Cascade)

  @@unique([planTierId, limitKey])
  @@index([planTierId])
}

// ── Business AI Advisor: Chat ──

model Conversation {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String
  title         String?                       // Auto-generated from first message
  lastMessageAt DateTime?
  messageCount  Int       @default(0)
  totalCostUsd  Float     @default(0)         // Running total of message costs
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  resolutionStatus String?                    // "resolved", "escalated", "abandoned", "failed"
  topicTags        String[]  @default([])
  agentRoleKey     String?                    // which agent role handled this conversation

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  messages Message[]

  @@index([tenantId])
  @@index([tenantId, userId, lastMessageAt])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  role            String                      // "user", "assistant", "system"
  content         String                      // Message text (markdown supported)
  toolCalls       Json?                       // Tool calls made by assistant
  toolResults     Json?                       // Results from tool execution
  inputTokens     Int?                        // Input tokens for this exchange
  outputTokens    Int?                        // Output tokens for this exchange
  costUsd         Float?                      // Estimated cost in USD
  durationMs      Int?                        // Response time in milliseconds
  feedbackRating  Int?                        // 1 = thumbs down, 5 = thumbs up
  feedbackComment String?                     // Optional feedback text
  createdAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ── AI Agent Prompt Management ──

model AgentType {
  id          String   @id @default(cuid())
  key         String   @unique           // "ocr_extraction", "product_matching", "prompt_management"
  name        String                      // "Invoice OCR", "Product Matching"
  description String?
  model       String   @default("claude-sonnet-4-20250514")
  maxTokens   Int      @default(4096)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  promptTemplates PromptTemplate[]
}

model PromptTemplate {
  id           String   @id @default(cuid())
  agentTypeId  String
  version      Int      @default(1)
  preamble     String   @db.Text        // structural header (role, JSON schema)
  postamble    String?  @db.Text        // closing instructions
  isActive     Boolean  @default(true)  // only one active version per agent
  createdAt    DateTime @default(now())
  createdBy    String?                  // userId of admin who created this version

  agentType  AgentType         @relation(fields: [agentTypeId], references: [id])
  conditions PromptCondition[]

  @@unique([agentTypeId, version])
  @@index([agentTypeId])
}

model PromptCondition {
  id               String   @id @default(cuid())
  promptTemplateId String
  orderIndex       Int                     // sort order within the prompt
  category         String   @default("rule") // "rule", "format", "constraint", "example"
  key              String                   // machine-readable key e.g. "gst_detection"
  text             String   @db.Text        // the actual instruction text
  isRequired       Boolean  @default(false) // if true, tenants cannot remove this
  validationKey    String?                  // named validator fn key e.g. "has_gst_invoices"
  validationDesc   String?                  // human-readable description of what the test checks
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  promptTemplate     PromptTemplate        @relation(fields: [promptTemplateId], references: [id], onDelete: Cascade)
  tenantOverrides    TenantPromptOverride[]
  conflicts          PromptConflict[]

  @@unique([promptTemplateId, key])
  @@index([promptTemplateId])
}

model TenantPromptOverride {
  id                String   @id @default(cuid())
  tenantId          String
  promptConditionId String?               // null if this is a tenant-added condition
  agentTypeKey      String                // denormalized: "ocr_extraction"
  action            String                // "add", "remove", "replace"
  customText        String?  @db.Text     // tenant-specific text (for "add" and "replace")
  orderIndex        Int      @default(999)
  category          String   @default("rule")
  isActive          Boolean  @default(true)
  createdBy         String?               // userId
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  promptCondition PromptCondition? @relation(fields: [promptConditionId], references: [id])

  @@index([tenantId])
  @@index([tenantId, agentTypeKey])
  @@index([promptConditionId])
}

model PromptConflict {
  id                  String    @id @default(cuid())
  tenantId            String
  promptConditionId   String                // the generic condition being challenged
  tenantOverrideText  String    @db.Text    // the tenant text that conflicts
  detectedReason      String?               // AI explanation of the conflict
  resolution          String?               // "keep_generic", "keep_tenant", "merge", null=unresolved
  resolvedBy          String?               // userId
  resolvedAt          DateTime?
  validationPassed    Boolean?              // did the safety test pass?
  validationOutput    String?   @db.Text    // test output/error
  createdAt           DateTime  @default(now())

  promptCondition PromptCondition @relation(fields: [promptConditionId], references: [id])

  @@index([tenantId])
  @@index([tenantId, promptConditionId])
}

model PromptChangeLog {
  id                  String   @id @default(cuid())
  tenantId            String
  userId              String?
  agentTypeKey        String                // "ocr_extraction", "product_matching"
  changeType          String                // "add_override", "remove_override", "replace_condition", "resolve_conflict", "revert"
  conditionKey        String?               // which generic condition affected
  previousText        String?  @db.Text
  newText             String?  @db.Text
  reason              String   @db.Text     // user's request / AI summary of why
  conversationExcerpt String?  @db.Text     // relevant chat exchange
  createdAt           DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, agentTypeKey])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Prompt Evolution System (Phase 1 — coexists with old prompt models above)
// ═══════════════════════════════════════════════════════════════════════════════

model AgentRole {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?  @db.Text
  model       String   @default("claude-sonnet-4-20250514")
  maxTokens   Int      @default(4096)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  baseVersions          PromptBaseVersion[]
  tenantConfigs         TenantPromptConfig[]
  tenantFewShotExamples TenantFewShotExample[]
  interactionSignals    InteractionSignal[]
  suggestions           PromptSuggestion[]
  auditLogs             PromptAuditLog[]
}

model PromptBaseVersion {
  id                  String   @id @default(cuid())
  agentRoleId         String
  versionNumber       Int
  content             Json                    // { systemPrompt, sections[], toolDefinitions[], outputFormat }
  isActive            Boolean  @default(false)
  parentVersionId     String?
  changeReason        String   @db.Text
  performanceSnapshot Json?
  createdBy           String?
  createdAt           DateTime @default(now())

  agentRole     AgentRole          @relation(fields: [agentRoleId], references: [id])
  parentVersion PromptBaseVersion? @relation("VersionLineage", fields: [parentVersionId], references: [id])
  childVersions PromptBaseVersion[] @relation("VersionLineage")

  tenantConfigs TenantPromptConfig[]
  signals       InteractionSignal[]
  auditLogs     PromptAuditLog[]

  @@unique([agentRoleId, versionNumber])
  @@index([agentRoleId, isActive])
  @@index([agentRoleId])
}

model TenantPromptConfig {
  id                        String   @id @default(cuid())
  tenantId                  String
  agentRoleId               String
  baseVersionId             String
  versionNumber             Int      @default(1)
  isActive                  Boolean  @default(true)

  toneSettings              Json?
  customInstructions        Json?
  domainTerminology         Json?
  escalationRules           Json?
  knowledgeSourcePriorities Json?
  enabledCapabilities       Json?

  updatedBy                 String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  agentRole   AgentRole         @relation(fields: [agentRoleId], references: [id])
  baseVersion PromptBaseVersion @relation(fields: [baseVersionId], references: [id])
  signals     InteractionSignal[]
  auditLogs   PromptAuditLog[]

  @@unique([tenantId, agentRoleId, versionNumber])
  @@index([tenantId, agentRoleId, isActive])
  @@index([tenantId, agentRoleId])
  @@index([baseVersionId])
}

model TenantFewShotExample {
  id                   String    @id @default(cuid())
  tenantId             String
  agentRoleId          String
  inputText            String    @db.Text
  idealOutputText      String    @db.Text
  sourceConversationId String?
  qualityScore         Float     @default(0)
  timesUsed            Int       @default(0)
  lastUsedAt           DateTime?
  isActive             Boolean   @default(false)
  autoCurated          Boolean   @default(false)
  tags                 String[]  @default([])
  createdBy            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  agentRole AgentRole @relation(fields: [agentRoleId], references: [id])

  @@index([tenantId, agentRoleId, isActive])
  @@index([tenantId, agentRoleId])
  @@index([tenantId, qualityScore])
  @@index([sourceConversationId])
}

model InteractionSignal {
  id                    String   @id @default(cuid())
  conversationId        String?
  tenantId              String
  agentRoleId           String
  baseVersionUsed       String
  configVersionUsed     String?

  resolutionStatus      String   @default("unknown")
  userSatisfactionScore Int?
  humanOverride         Boolean  @default(false)
  humanOverrideDiff     Json?
  correctionCount       Int      @default(0)
  escalationOccurred    Boolean  @default(false)
  failureReason         String?  @db.Text

  topicTags             String[] @default([])
  tokenCount            Int      @default(0)
  latencyMs             Int      @default(0)
  costUsd               Float    @default(0)

  userId                String?
  timestamp             DateTime @default(now())

  agentRole   AgentRole          @relation(fields: [agentRoleId], references: [id])
  baseVersion PromptBaseVersion  @relation(fields: [baseVersionUsed], references: [id])
  config      TenantPromptConfig? @relation(fields: [configVersionUsed], references: [id])

  @@index([tenantId, agentRoleId, timestamp])
  @@index([tenantId, timestamp])
  @@index([agentRoleId, baseVersionUsed, timestamp])
  @@index([baseVersionUsed])
  @@index([tenantId, resolutionStatus])
  @@index([conversationId])
}

model PromptSuggestion {
  id                String    @id @default(cuid())
  tenantId          String?
  agentRoleId       String
  suggestionType    String
  suggestionContent Json
  evidence          Json
  impactEstimate    Json?

  status            String    @default("pending")
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewNotes       String?   @db.Text
  appliedAt         DateTime?

  source            String    @default("suggestion_engine")
  batchId           String?
  createdAt         DateTime  @default(now())

  agentRole AgentRole @relation(fields: [agentRoleId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, agentRoleId, status])
  @@index([status, createdAt])
  @@index([agentRoleId, source])
  @@index([batchId])
}

model PromptAuditLog {
  id              String   @id @default(cuid())
  tenantId        String?
  agentRoleId     String
  actionType      String

  beforeState     Json?
  afterState      Json

  triggeredBy     String
  approvedBy      String?
  suggestionId    String?
  reason          String?  @db.Text

  baseVersionId   String?
  tenantConfigId  String?

  timestamp       DateTime @default(now())

  agentRole    AgentRole          @relation(fields: [agentRoleId], references: [id])
  baseVersion  PromptBaseVersion? @relation(fields: [baseVersionId], references: [id])
  tenantConfig TenantPromptConfig? @relation(fields: [tenantConfigId], references: [id])

  @@index([tenantId, agentRoleId, timestamp])
  @@index([tenantId, timestamp])
  @@index([agentRoleId, timestamp])
  @@index([triggeredBy, timestamp])
  @@index([suggestionId])
}

// ── Product Import Pipeline Models ─────────────────────────────

model GlobalSourceRegistry {
  id               String     @id @default(cuid())
  key              String     @unique
  name             String
  displayName      String
  sourceType       SourceType
  description      String?
  expectedHeaders  Json?
  defaultMapping   Json?
  columnSignatures Json?
  isActive         Boolean    @default(true)
  isDefault        Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  tenantSources TenantSourceRegistry[] @relation("SourceTemplate")
}

model TenantSourceRegistry {
  id               String     @id @default(cuid())
  tenantId         String
  globalSourceId   String?
  key              String
  name             String
  displayName      String
  sourceType       SourceType
  description      String?
  expectedHeaders  Json?
  customMapping    Json?
  columnSignatures Json?
  syncMode         SyncMode   @default(FULL)
  isActive         Boolean    @default(true)
  webhookSecret    String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id])
  globalSource GlobalSourceRegistry? @relation("SourceTemplate", fields: [globalSourceId], references: [id])
  importJobs   ImportJob[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([globalSourceId])
}

model ImportJob {
  id                  String       @id @default(cuid())
  tenantId            String
  userId              String?
  status              ImportStatus @default(PENDING)
  sourceType          SourceType
  sourceName          String?
  tenantSourceId      String?
  fileName            String?
  fileHash            String?
  totalRows           Int?
  processedRows       Int          @default(0)
  columnMapping       Json?
  patterns            Json?
  gstDetected         Boolean      @default(false)
  gstRate             Float?
  hasVariants         Boolean      @default(false)
  groupByColumn       String?
  variantColumns      Json?
  syncMode            SyncMode     @default(FULL)
  dryRun              Boolean      @default(false)
  rowsCreated         Int          @default(0)
  rowsUpdated         Int          @default(0)
  rowsSkipped         Int          @default(0)
  rowsFailed          Int          @default(0)
  rowsPendingApproval Int          @default(0)
  errorSummary        Json?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id])
  user         User?                 @relation(fields: [userId], references: [id])
  tenantSource TenantSourceRegistry? @relation(fields: [tenantSourceId], references: [id])
  queueEntries ApprovalQueueEntry[]
  importRecords ProductImportRecord[]
  auditLogs    AuditLog[]
  products     Product[]             @relation("ProductImportJob")

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([status])
}

model ApprovalQueueEntry {
  id                     String               @id @default(cuid())
  tenantId               String
  importJobId            String
  rowIndex               Int
  approvalRoute          ApprovalRoute
  invoiceRiskLevel       InvoiceRiskLevel     @default(NONE)
  status                 ImportApprovalStatus @default(PENDING)
  normalizedData         Json
  matchResult            Json?
  similarProducts        Json?
  confidenceScore        Float?
  confidenceBreakdown    Json?
  riskExplanation        String?
  action                 ApprovalAction?
  actionedBy             String?
  actionedAt             DateTime?
  actionNotes            String?
  updatedFields          Json?
  linkedProductId        String?
  productId              String?
  slaDeadline            DateTime?
  requiresSecondApproval Boolean              @default(false)
  secondActionedBy       String?
  secondActionedAt       DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  importJob     ImportJob            @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  actionUser    User?                @relation("ApprovalActionUser", fields: [actionedBy], references: [id])
  importRecords ProductImportRecord[]

  @@index([tenantId, status])
  @@index([tenantId, invoiceRiskLevel])
  @@index([importJobId])
  @@index([productId])
  @@index([tenantId, createdAt])
}

model ProductImportRecord {
  id                    String       @id @default(cuid())
  tenantId              String
  importJobId           String
  rowIndex              Int
  rawSourceData         Json
  normalizedData        Json?
  fingerprintTier       Int?
  fingerprint           String?
  fingerprintComponents Json?
  matchAction           MatchAction?
  matchedProductId      String?
  matchScore            Float?
  matchedOn             Json?
  productId             String?
  approvalQueueId       String?
  processingError       String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  importJob     ImportJob            @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  product       Product?             @relation(fields: [productId], references: [id])
  approvalQueue ApprovalQueueEntry?  @relation(fields: [approvalQueueId], references: [id])

  @@unique([importJobId, rowIndex])
  @@index([tenantId])
  @@index([importJobId])
  @@index([productId])
  @@index([fingerprint])
}

// ── Product Import Pipeline Enums ──────────────────────────────

enum ImportStatus {
  PENDING
  ANALYZING
  AWAITING_CONFIRMATION
  PROCESSING
  COMPLETE
  PARTIAL
  FAILED
  CANCELLED
}

enum SourceType {
  CSV_UPLOAD
  SHOPIFY_SYNC
  GMAIL_ATTACHMENT
  FOLDER_FILE
  DRIVE_FILE
  MANUAL
  API_PUSH
}

enum ApprovalRoute {
  ROUTE_AUTO
  ROUTE_REVIEW
  ROUTE_REJECT
}

enum ImportApprovalStatus {
  PENDING
  AUTO_APPROVED
  APPROVED
  REJECTED
}

enum ApprovalAction {
  APPROVE
  REJECT
  DEFER
  OVERRIDE
}

enum InvoiceRiskLevel {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MatchAction {
  CREATED
  UPDATED
  SKIPPED
  MERGED
  FAILED
}

enum SyncMode {
  FULL
  INCREMENTAL
}

enum AuditTriggerSource {
  UI_ACTION
  SYSTEM_PROCESS
}

// ── AI Service Abstraction Layer (ASAL) ───────────────────────────

model AiServiceRegistry {
  id                String   @id @default(cuid())
  intent            String   // 'EMBEDDING', 'RERANKING', 'TEXT_GENERATION'
  taskKey           String   @unique // e.g. 'product_matching', 'strategic_advice'
  description       String
  provider          String   // e.g. 'anthropic', 'cohere'
  model             String   // e.g. 'claude-sonnet-4-20250514', 'embed-english-v3.0'
  config            Json     @default("{}")
  fallbackProvider  String?
  fallbackModel     String?
  isActive          Boolean  @default(true)
  costPerUnit       Decimal? // e.g. 3.00 (dollars per million tokens)
  costUnit          String?  // e.g. 'per_million_input_tokens', 'per_1000_searches'
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([intent])
  @@index([isActive])
}

model AiServiceLog {
  id              String   @id @default(cuid())
  tenantId        String?  // null for platform-level calls
  intent          String
  taskKey         String
  provider        String
  model           String
  isFallback      Boolean  @default(false)
  inputTokens     Int?
  outputTokens    Int?
  latencyMs       Int
  estimatedCost   Decimal?
  status          String   // 'success', 'failure', 'fallback_success'
  errorCode       String?
  createdAt       DateTime @default(now())

  tenant          Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([taskKey, createdAt])
  @@index([provider, createdAt])
}

// ── Product Embedding Storage (ASAL Step 2) ──

model ProductEmbedding {
  id            String   @id @default(cuid())
  tenantId      String
  productId     String
  model         String   // e.g. 'embed-english-v3.0' — tracks which model generated this
  embeddingText String   // the text that was embedded (for debugging/re-embedding)
  // vector column added via raw SQL — not in Prisma schema (unsupported type)
  dimensions    Int      @default(1024)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])

  @@unique([productId, model])  // one embedding per product per model
  @@index([tenantId])
  @@index([productId])
}
